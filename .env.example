# Supabase
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-from-supabase-status
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-from-supabase-status

# Kitchen session signing secret (qualquer string aleatória robusta)
# Gerar com: openssl rand -hex 32
KITCHEN_SESSION_SECRET=replace-with-random-32+-bytes-hex

# Default tempo médio de preparo em segundos (fallback se evento não definir)
NEXT_PUBLIC_DEFAULT_TEMPO_PREPARO=300
